# Root URL of your TTS server (OmniVoice). No /v1 suffix — the proxy forwards
# the request path (including /v1) verbatim, matching how Open WebUI calls it.
UPSTREAM_BASE_URL=http://omnivoice:8880

# Host/port the proxy listens on. Point Open WebUI's TTS API base URL here
# with a /v1 suffix, e.g. http://thai-tts-proxy:8080/v1
LISTEN_HOST=0.0.0.0
LISTEN_PORT=8080

# Optional: override/force the Authorization header sent upstream.
# Leave blank to forward whatever Open WebUI sends.
UPSTREAM_API_KEY=

# Normalization toggles.
NORMALIZE_NUMBERS=true
NORMALIZE_MAIYAMOK=true

# How a *mentioned* ๆ is rendered. Here "mentioned" means the sole content
# of a matched quote/code span (the delimiter-detected case; CONTEXT.md uses
# the term more broadly — a bare ๆ elsewhere is not affected by this mode).
# A ๆ *used* as a repetition mark (ดีๆ) is always expanded regardless.
#   keep  = emit the ๆ verbatim (default)
#   name  = replace with ไม้ยมก (its spoken name)
#   strip = remove it entirely
# Any unrecognised value falls back to "keep" with a warning.
YAMOK_MENTION_RENDER=keep

# How the word to repeat for a *used* ๆ (ดีๆ) is found. "off" (default)
# repeats the last Thai run -- stdlib-only, but it over-repeats when words
# are not space-separated (issue #2). "pythainlp" segments the preceding
# text and repeats only the last word; it needs the OPTIONAL `pythainlp`
# package (`pip install pythainlp`) -- if that isn't installed the proxy
# falls back to "off" with a warning. See ADR-0001.
YAMOK_SEGMENTER=off

# Connect/write timeout in seconds. Audio streaming has no read timeout.
REQUEST_TIMEOUT=120

LOG_LEVEL=INFO
